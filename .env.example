# AI 学习助手 - 环境变量配置示例
# 复制此文件为 backend/.env 或在部署平台环境变量中配置实际值。

# ===== 必需配置 =====

# DeepSeek 文本对话模型
# 注意：不要把真实 API Key 提交到代码仓库。
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_ENABLE_THINKING=true
DEEPSEEK_REASONING_EFFORT=high

# JWT 密钥（用于用户认证）
JWT_SECRET=your_jwt_secret_key

# ===== 可选配置：图像识别 =====

# 图像识别需要视觉模型。DeepSeek 当前这里配置的是文本对话模型，
# 如果要继续使用拍照识题/OCR，请单独配置兼容 OpenAI chat completions 的视觉模型。
MULTIMODAL_API_KEY=your_multimodal_api_key
MULTIMODAL_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
MULTIMODAL_MODEL=glm-4.6v-flashx

# ===== 可选运行配置 =====

REQUEST_TIMEOUT=120
MAX_IMAGE_SIZE=5242880
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
CORS_ORIGIN=http://localhost:8080
